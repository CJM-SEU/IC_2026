 <Module Name="partialproduct1" Comment="" Class="partialproduct" Parent="boothandwallacetest" Code="always@(a or b)&#xa;  begin&#xa; case(b[1:0])&#xa;  2'b00:p1[15:0]=0;&#xa;  2'b01:begin&#xa;       p1[7:0]=a[7:0];&#xa;       if(a[7]==1) p1[15:8]='b11111111;&#xa;       else p1[15:8]='b00000000;&#xa;      end&#xa;  2'b10:begin&#xa;         p1[8:1]=a[7:0];&#xa;         p1[0]='b0;&#xa;         p1[8:0]=~p1[8:0]+1;&#xa;         if(a[7]==0) p1[15:9]='b1111111;&#xa;         else p1[15:9]='b0000000;&#xa;      end&#xa;  2'b11:begin&#xa;         p1[7:0]=a[7:0];&#xa;         p1[7:0]=~p1[7:0]+'b00000001;&#xa;         if(a[7]==0) p1[15:8]='b11111111;&#xa;         else p1[15:8]='b00000000;&#xa;      end&#xa; endcase&#xa; case(b[3:1])&#xa;   3'b000,&#xa;   3'b111:p2[15:0]=0;&#xa;   3'b001,&#xa;   3'b010: begin&#xa;           p2[9:2]=a[7:0];&#xa;           p2[1:0]='b00;&#xa;           if(a[7]==1) p2[15:10]='b111111;&#xa;           else p2[15:10]='b000000;&#xa;          end&#xa;   3'b011:begin&#xa;           p2[10:3]=a[7:0];&#xa;           p2[2:0]='b000;&#xa;           if(a[7]==1) p2[15:11]='b11111;&#xa;           else p2[15:11]='b00000;&#xa;          end&#xa;   3'b100:begin&#xa;           p2[10:3]=a[7:0];&#xa;           p2[2]='b0;&#xa;           p2[10:2]=~p2[10:2]+1;&#xa;           p2[1:0]='b00;&#xa;           if(a[7]==0) p2[15:11]='b11111;&#xa;           else p2[15:11]='b00000;&#xa;          end&#xa;   3'b101,&#xa;   3'b110:begin&#xa;           p2[9:2]=a[7:0];&#xa;           p2[9:2]=~(p2[9:2])+'b00000001;&#xa;           p2[1:0]='b00;&#xa;           if(a[7]==0) p2[15:10]='b111111;&#xa;           else p2[15:10]='b000000;&#xa;          end&#xa; endcase&#xa; case(b[5:3])&#xa;   3'b000,&#xa;   3'b111:p3[15:0]=0;&#xa;   3'b001,&#xa;   3'b010:begin&#xa;           p3[11:4]=a[7:0];&#xa;           p3[3:0]='b0000;&#xa;           if(a[7]==1) p3[15:12]='b1111;&#xa;           else p3[15:12]='b0000;&#xa;          end&#xa;   3'b011:begin&#xa;           p3[12:5]=a[7:0];&#xa;           p3[4:0]='b00000;&#xa;           if(a[7]==1) p3[15:13]='b111;&#xa;           else p3[15:13]='b000;&#xa;          end&#xa;   3'b100:begin&#xa;           p3[12:5]=a[7:0];&#xa;           p3[4]='b0;&#xa;           p3[12:4]=~(p3[12:4])+'b00000001;&#xa;           p3[3:0]='b0000;&#xa;           if(a[7]==0) p3[15:13]='b111;&#xa;           else p3[15:13]='b000;&#xa;          end&#xa;    3'b101,&#xa;    3'b110:begin&#xa;           p3[11:4]=a[7:0];&#xa;           p3[11:4]=~(p3[11:4])+'b00000001;&#xa;           p3[3:0]='b0000;&#xa;           if(a[7]==0) p3[15:12]='b1111;&#xa;           else p3[15:12]='b0000;&#xa;          end&#xa; endcase&#xa; case(b[7:5])&#xa;    3'b000,&#xa;    3'b111:p4[15:0]=0;&#xa;    3'b001,&#xa;    3'b010:begin&#xa;           p4[13:6]=a[7:0];&#xa;           p4[5:0]='b000000;&#xa;           if(a[7]==1) p4[15:14]='b11;&#xa;           else p4[15:14]='b00;&#xa;          end&#xa;    3'b011:begin&#xa;           p4[14:7]=a[7:0];&#xa;           p4[6:0]='b0000000;&#xa;           if(a[7]==1) p4[15]='b1;&#xa;           else p4[15]='b0;&#xa;          end&#xa;     3'b100:begin&#xa;           p4[14:7]=a[7:0];&#xa;           p4[14:7]=~(p4[14:7])+'b00000001;&#xa;           p4[6:0]='b0000000;&#xa;           if(a[7]==0) p4[15]='b1;&#xa;           else p4[15]='b0;&#xa;          end&#xa;     3'b101,&#xa;     3'b110:begin&#xa;           p4[13:6]=a[7:0];&#xa;           p4[13:6]=~(p4[13:6])+'b00000001;&#xa;           p4[5:0]='b000000;&#xa;           if(a[7]==0) p4[15:14]='b11;&#xa;           else p4[15:14]='b00;&#xa;          end&#xa;  endcase&#xa;end&#xa;&#xa;" Type="model" X="320.752" File="Current/partialproduct.model" Parameters="" Y="174.586" Width="120" Color="#f5f5dc" Height="120">
